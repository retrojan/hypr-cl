
[global]
    monitor = 0
    follow = mouse

    width = (320)
    height = (0, 180)
    origin = top-right
    offset = (15, 50)
    scale = 0
    notification_limit = 8

    padding = 6
    horizontal_padding = 6
    text_icon_padding = 6
    frame_width = 2
    gap_size = 3
    
    icon_corner_radius = 6
    icon_corners = all
    min_icon_size = 20
    max_icon_size = 40
    icon_position = left
    
    font = "JetBrains Mono Nerd Font 12"
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    progress_bar = true
    progress_bar_height = 5
    progress_bar_frame_width = 0
    progress_bar_min_width = 120
    progress_bar_max_width = 250
    progress_bar_corner_radius = 3
    progress_bar_corners = all

    indicate_hidden = yes
    transparency = 0
    separator_height = 0
    separator_color = frame
    sort = yes
    
    corner_radius = 20
    corners = all

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = context

[urgency_low]
    background = "#313244"
    foreground = "#cdd6f4"
    frame_color = "#585b70"
    timeout = 5
    default_icon = dialog-information

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#bb9af7"
    timeout = 8
    default_icon = dialog-information

[urgency_critical]
    background = "#f38ba8"
    foreground = "#11111b"
    frame_color = "#f9e2af"
    timeout = 0
    default_icon = dialog-warning
